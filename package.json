{
  "name": "nearcade",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "fl": "prettier --write . && eslint . --fix",
    "m": "tsx ./scripts/manage-messages.js",
    "mw": "tsx ./scripts/manage-messages.js --write && prettier --write ./messages",
    "ssv-poll": "tsx ./scripts/ssv-email-worker.ts",
    "wechat-refresh": "tsx ./scripts/refresh-wechat-token.ts",
    "maintain-attendance": "tsx ./scripts/attendance-maintainer.ts",
    "calc-uni-stats": "tsx ./scripts/update-university-stats.ts",
    "migrate-notifications": "tsx ./scripts/migrate-notifications.ts",
    "cf-deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types ./src/worker-configuration.d.ts"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-auto": "^7.0.1",
