    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.6.0",
    "@types/node-imap": "^0.9.3",
    "@types/three": "^0.184.0",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "@types/xml2js": "^0.4.14",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
